DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/hotel_app
COMPETITOR_SCRAPE_COUNTRY=vn
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=auto
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=qwen3.5:cloud
OLLAMA_TIMEOUT_SECONDS=60

# Owner automation (digest + threshold webhooks). Set AUTOMATION_ENABLED=true to run jobs inside uvicorn.
AUTOMATION_ENABLED=false
AUTOMATION_TIMEZONE=Asia/Ho_Chi_Minh
AUTOMATION_DIGEST_CRON_HOUR=7
AUTOMATION_DIGEST_CRON_MINUTE=0
AUTOMATION_EVAL_INTERVAL_MINUTES=30
AUTOMATION_ALERT_COOLDOWN_HOURS=6
AUTOMATION_DIGEST_SCOPE=combined
AUTOMATION_DASHBOARD_BASE_URL=http://localhost:5173
AUTOMATION_TRIGGER_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

AUTOMATION_DIGEST_EMAIL_TO=
AUTOMATION_TELEGRAM_BOT_TOKEN=
AUTOMATION_TELEGRAM_CHAT_IDS=
AUTOMATION_DIGEST_SLACK_WEBHOOKS=
AUTOMATION_ALERT_SLACK_WEBHOOKS=
AUTOMATION_EXTRA_ALERT_WEBHOOKS=
